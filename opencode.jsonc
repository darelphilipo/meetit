{
  "$schema": "https://opencode.ai/config.json",
  // IMPORTANT: Verify these exact model IDs match your opencode-go subscription.
  // If opencode fails to start, check the correct IDs in your dashboard.
  "model": "opencode-go/minimax-m2.7",
  "default_agent": "orchestrator",
  "agent": {
    "orchestrator": {
      "model": "opencode-go/qwen3.7-max",
      "mode": "primary",
      "description": "Analyzes tasks, plans architecture, and delegates coding work to the general subagent. Handles non-coding questions directly."
    },
    "general": {
      "model": "opencode-go/minimax-m2.7",
      "description": "Coding agent that implements, edits, tests, and debugs code when delegated by the orchestrator."
    }
  }
}
