{
  "$schema": "https://developers.reddit.com/schema/config-file.v1.json",
  "name": "meetup-hub2",
  "post": {
    "dir": "public",
    "entrypoints": {
      "default": {
        "entry": "app.html",
        "height": "tall",
        "inline": true
      }
    }
  },
  "server": {
    "entry": "index.js"
  },
  "permissions": {
    "http": {
      "enable": true,
      "domains": []
    },
    "redis": true,
    "reddit": {
      "enable": true,
      "scope": "moderator",
      "asUser": ["SUBMIT_POST"]
    }
  },
  "menu": {
    "items": [
      {
        "label": "Create Meetit Post",
        "description": "meetit",
        "location": "subreddit",
        "endpoint": "/internal/menu/create-post"
      }
    ]
  },
  "triggers": {
    "onAppInstall": "/internal/on-app-install",
    "onAppUpgrade": "/internal/on-app-upgrade"
  },
  "scheduler": {
    "tasks": {
      "check-events": {
        "endpoint": "/internal/scheduler/check-events",
        "cron": "*/5 * * * *"
      }
    }
  },
  "settings": {
    "subreddit": {
      "primary_color": {
        "type": "string",
        "label": "Primary Color",
        "defaultValue": "#ffff00"
      },
      "secondary_color": {
        "type": "string",
        "label": "Secondary Color",
        "defaultValue": "#ff69b4"
      },
      "use_brutalist_borders": {
        "type": "boolean",
        "label": "Use Brutalist Borders",
        "defaultValue": true
      },
      "mod_usernames": {
        "type": "string",
        "label": "Moderator Usernames (comma-separated)",
        "defaultValue": ""
      },
      "reminder_hours": {
        "type": "number",
        "label": "Reminder: Hours Before Event (e.g. 24 = 1 day before)",
        "defaultValue": 24
      },
      "timezone": {
        "type": "select",
        "label": "Community Timezone (for event reminders)",
        "helpText": "Events and reminders use this timezone. Default is IST.",
        "options": [
          { "label": "India (IST, +5:30)", "value": "+05:30" },
          { "label": "US East (EST, -5:00)", "value": "-05:00" },
          { "label": "US West (PST, -8:00)", "value": "-08:00" },
          { "label": "UK (GMT, +0:00)", "value": "+00:00" },
          { "label": "Central Europe (CET, +1:00)", "value": "+01:00" },
          { "label": "Japan (JST, +9:00)", "value": "+09:00" },
          { "label": "Australia (AEDT, +11:00)", "value": "+11:00" },
          { "label": "UTC", "value": "+00:00" }
        ],
        "defaultValue": "+05:30"
      }
    }
  },
  "scripts": {
    "dev": "node --experimental-strip-types ./tools/build.ts --watch",
    "build": "node --experimental-strip-types ./tools/build.ts --minify"
  },
  "dev": {
    "subreddit": "meetup_hub2_dev"
  }
}